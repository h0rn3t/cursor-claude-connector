# --- Upstash Redis (required to persist OAuth tokens) ---
# Get these from your Upstash Redis dashboard: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token

# --- Optional: API key for the proxy itself ---
# When set, callers must send `Authorization: Bearer <API_KEY>`.
# Leave empty to disable the extra auth layer.
API_KEY=custom-key

# --- Optional: Anthropic OAuth client id ---
# Defaults to the official Claude CLI id; override only if you maintain
# your own OAuth application.
# ANTHROPIC_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e

# --- Optional: server port (default 9095) ---
# PORT=9095